# Copy to .env locally (never commit .env)

# --- Backend (Railway / local) ---
DATABASE_URL=postgresql://user:password@localhost:5432/threatvision
ENCRYPTION_KEY=
INTERNAL_JWT_SECRET=
INTERNAL_JWT_EXPIRE_MINUTES=5
BFF_SERVICE_KEY=
API_KEY_PEPPER=
SUPERADMIN_EMAIL=you@example.com
# Must match the single bootstrap superadmin account (lowercased compare)
GEMINI_API_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Vercel / local) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Server-side in Next.js: FastAPI URL for BFF proxy + register API route (same file can reuse BFF_SERVICE_KEY above)
BACKEND_URL=http://localhost:8000

# Copy to .env locally (never commit .env)

# --- Backend (Railway / local) ---
DATABASE_URL=postgresql://user:password@localhost:5432/threatvision
# Supabase / Neon / any TLS-only Postgres: set require (see README — Supabase section)
# DATABASE_SSL=require
ENCRYPTION_KEY=
INTERNAL_JWT_SECRET=
INTERNAL_JWT_EXPIRE_MINUTES=5
BFF_SERVICE_KEY=
API_KEY_PEPPER=
SUPERADMIN_EMAIL=you@example.com
# Must match the single bootstrap superadmin account (lowercased compare)
GEMINI_API_KEY=

# CORS (comma-separated origins; set your Vercel URL in production)
CORS_ORIGINS=http://localhost:3000

# Max JSON body size for POST/PUT/PATCH (bytes, min 65536, max 104857600; default 8388608)
MAX_REQUEST_BODY_BYTES=8388608

# Local only: allow login with email "admin" + password "admin" (maps to admin@threatvision.dev). Set false in production.
DEV_QUICK_ADMIN_LOGIN=false

# Optional: Docker MISP — run backend/scripts/set_platform_misp_from_env.py (writes DB + these lines for API fallback).
# MISP_TLS_VERIFY=false
# PLATFORM_MISP_URL=https://127.0.0.1
# PLATFORM_MISP_API_KEY=   (filled by script; used if platform_settings decrypt fails)
# MISP_DOCKER_MISP_CONTAINER=misp-misp-core-1
# MISP_DOCKER_DB_CONTAINER=misp-db-1
# MISP_DOCKER_ADMIN_EMAIL=admin@admin.test

# --- Frontend (Vercel / local) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Server-side in Next.js: FastAPI URL for BFF proxy + register API route (same file can reuse BFF_SERVICE_KEY above)
BACKEND_URL=http://127.0.0.1:8001
